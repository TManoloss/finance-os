# Database configuration
POSTGRES_DB=postgres
POSTGRES_USER=seu_usuario_supabase
POSTGRES_PASSWORD=sua_senha_supabase
DB_PORT=6543
DATABASE_URL=postgresql://seu_usuario_supabase:sua_senha_supabase@seu_host_supabase:6543/postgres


# Backend configuration (Go)
PORT=8080
JWT_SECRET=seu_secret_aqui
JWT_REFRESH_SECRET=seu_refresh_secret_aqui
CORS_ORIGINS=*
ENCRYPTION_KEY=seu_encryption_key_32_bytes_base64_aqui

# Pluggy configuration
PLUGGY_CLIENT_ID=seu_client_id_aqui
PLUGGY_CLIENT_SECRET=seu_client_secret_secret_aqui

# Agents configuration (Python)
AGENTS_PORT=8000
AGENTS_SERVICE_URL=http://localhost:8000
GO_BACKEND_URL=http://localhost:8080
LLM_PROVIDER=groq # groq ou gemini
GROQ_API_KEY=sua_chave_groq_aqui
GOOGLE_API_KEY=sua_chave_gemini_aqui

# Sync & Keep-alive
# Gere uma string aleatória forte: openssl rand -hex 32
SYNC_SECRET=
# URL do serviço no Render (ex: https://finance-os-api.onrender.com)
SELF_URL=

# Adminer configuration
ADMINER_PORT=8082
